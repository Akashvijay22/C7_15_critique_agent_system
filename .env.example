# Copy to .env and fill in. Only OPENROUTER_API_KEY is required.
# Get a key at https://openrouter.ai/keys  (or paste it in the app sidebar).

OPENROUTER_API_KEY=your-openrouter-key-here

# Optional overrides (defaults shown)
CRITIQUE_MODEL=openai/gpt-4o-mini
REDESIGN_MODEL=google/gemini-2.5-flash-image
STRUCTURED_OUTPUT_METHOD=function_calling
EMBEDDING_MODEL=all-MiniLM-L6-v2
LANCEDB_PATH=./.lancedb
RETRIEVAL_K=4
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2000
LLM_TIMEOUT=120
DEDUP_THRESHOLD=0.82

# App attribution sent to OpenRouter
APP_URL=https://localhost
APP_NAME=Multimodal UI/UX Critique Suite

# Optional: LangSmith tracing
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=your-langsmith-key-here
